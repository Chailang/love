
.container {
  background: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.banner {
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 200rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  gap: 20rpx;
}

.category-item {
  width: calc((100% - 60rpx) / 4);
  background: white;
  border-radius: 16rpx;
  padding: 24rpx 10rpx;
  text-align: center;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.category-title {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.category-count {
  font-size: 22rpx;
  color: #999;
}

.section {
  margin-top: 20rpx;
  padding: 0 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.user-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.user-name-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.user-age {
  font-size: 26rpx;
  color: #666;
}

.user-job {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  background: #f0f0f0;
  color: #666;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

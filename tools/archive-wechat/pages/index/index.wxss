
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #ffffff 0%, #fafafa 100%);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  height: 88rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.filter-icon {
  font-size: 40rpx;
  padding: 10rpx;
}

.card-container {
  flex: 1;
  padding: 20rpx 30rpx;
  position: relative;
  overflow: hidden;
}

.card-stack {
  width: 100%;
  height: 100%;
  position: relative;
}

.user-card {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  overflow: hidden;
  background: white;
  transition: transform 0.3s ease;
}

.card-bg {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.card-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  color: white;
}

.basic-info {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.name {
  font-size: 48rpx;
  font-weight: bold;
}

.age {
  font-size: 28rpx;
  opacity: 0.95;
}

.job-location {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.distance {
  font-size: 24rpx;
  opacity: 0.85;
}

/* 滑屏标签 */
.nope-label {
  position: absolute;
  top: 60rpx;
  left: 40rpx;
  transform: rotate(-15deg);
  border: 6rpx solid #ff6b6b;
  color: #ff6b6b;
  font-size: 48rpx;
  font-weight: bold;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  opacity: 0.8;
}

.like-label {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  transform: rotate(15deg);
  border: 6rpx solid #4cd964;
  color: #4cd964;
  font-size: 48rpx;
  font-weight: bold;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  opacity: 0.8;
}

.action-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 30rpx;
  padding: 30rpx 0;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  background: transparent;
}

.action-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
}

.action-btn .btn-icon {
  font-size: 48rpx;
}

.nope-btn {
  width: 80rpx;
  height: 80rpx;
}

.super-like-btn {
  width: 70rpx;
  height: 70rpx;
}

.like-btn {
  width: 80rpx;
  height: 80rpx;
}

.loading, .no-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #999;
  font-size: 28rpx;
}

.refresh-btn {
  margin-top: 30rpx;
  background: #ff6b6b;
  color: white;
  border-radius: 50rpx;
  border: none;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
}

.refresh-btn::after {
  border: none;
}
